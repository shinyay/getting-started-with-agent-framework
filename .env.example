# ===== Microsoft Foundry / Agent Framework 1.2.2 (Demo 1-3, 5, 7) =====
# Renamed from AZURE_AI_PROJECT_ENDPOINT in Agent Framework 1.0+ GA migration.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4.1-mini

# Hosted Web Search (Demo 2) requires a Bing connection in the Foundry project.
# Use ONE of the following configurations.

# A) Grounding with Bing Search (recommended)
BING_CONNECTION_ID=

# B) Bing Custom Search
# BING_CUSTOM_CONNECTION_ID=
# BING_CUSTOM_INSTANCE_NAME=

# ===== Demo 7 (optional): Foundry Toolboxes + Hosted Agent V2 =====
# Set these to consume an existing Toolbox / Hosted Agent in your Foundry project.
# Demo 7 fails-soft (prints fix-up instructions) when these are not set.
# FOUNDRY_TOOLBOX_NAME=
# FOUNDRY_AGENT_NAME=
# FOUNDRY_AGENT_VERSION=

# ===== Azure OpenAI (used in some demos like Demo 6 — DevUI / ai_genius_workflow) =====
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_API_KEY=

# (optional) AZURE_OPENAI_API_VERSION=2024-xx-xx


